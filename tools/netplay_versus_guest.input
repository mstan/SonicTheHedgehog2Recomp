# Mirror the deterministic menu setup on both emulated machines. Only the
# guest-owned controller movement below differs and travels through netplay.
WAIT 700
PRESS START 2
WAIT 90
WRITE_RAM8 FFFF86 01
PRESS START 2
WAIT_RAM8 FFF600 1C
WAIT 60
PRESS START 2
WAIT 90
PRESS START 2
WAIT 90
PRESS START 2
WAIT_RAM8 FFF600 0C
WAIT 120
HOLD RIGHT
