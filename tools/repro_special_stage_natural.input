# Enter gameplay first, then load the user's native save state. The orbiting
# checkpoint stars become collidable shortly after load; jump once that happens
# and assert the real star-touch path switches into special-stage mode.
WAIT 700
PRESS START 2
WAIT 90
PRESS START 2
WAIT_RAM8 FFF600 8C
WAIT_RAM8 FFF600 0C
WAIT 30
LOAD_STATE native_save_1.bin
WAIT 65
HOLD A
WAIT 120
SCREENSHOT special_stage_repro.png
WAIT 1200
EXIT 0
