# Enter gameplay first, load the user's native save, and dump canonical
# byte-ordered WRAM snapshots around the quick jump into the checkpoint ring.
WAIT 700
PRESS START 2
WAIT 90
PRESS START 2
WAIT_RAM8 FFF600 0C
WAIT 30
LOAD_STATE native_save_1.bin
DUMP_RAM ss_after_load.bin
HOLD A
WAIT 1
DUMP_RAM ss_after_jump_001.bin
WAIT 9
DUMP_RAM ss_after_jump_010.bin
WAIT 20
DUMP_RAM ss_after_jump_030.bin
WAIT 60
DUMP_RAM ss_after_jump_090.bin
EXIT 0
