# Select the native two-player versus entry from Sonic 2's title menu.
WAIT 700
PRESS START 2
WAIT 90
# Select 2P VS directly; menu animation timing can otherwise make a scripted
# DOWN land on the special-stage option under different net delays.
WRITE_RAM8 FFFF86 01
PRESS START 2
WAIT_RAM8 FFF600 1C
WAIT 60
PRESS START 2
WAIT 90
PRESS START 2
WAIT 90
PRESS START 2
WAIT_RAM8 FFF600 0C
